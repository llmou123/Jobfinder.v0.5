<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    >
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/textView3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Publish Job"
            android:textColor="@color/gray"
            android:textSize="27sp" />

        <View
            android:id="@+id/view"
            android:layout_width="40dp"
            android:layout_height="5dp"
            android:layout_below="@id/textView3"
            android:layout_alignStart="@+id/textView3"
            android:background="@drawable/light_bg"
            android:backgroundTint="@color/dark_black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/view"
            android:layout_marginTop="10dp"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="15dp"
                android:background="@drawable/stroke_bg"
                app:cardCornerRadius="18dp">

                <ImageView
                    android:id="@+id/job_image"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:scaleType="centerCrop"
                    android:background="@color/white"/>
                <View
                    android:id="@+id/view2"
                    android:layout_width="wrap_content"
                    android:layout_height="170dp"
                    android:background="@drawable/stroke_bg" />

                <TextView
                    android:id="@+id/b_selectImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Select an Image!!"
                    android:textColor="@color/black"
                    android:textSize="21sp" />
            </androidx.cardview.widget.CardView>




            <EditText
                android:id="@+id/new_post_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="8dp"
                android:hint="Title"
                android:background="@drawable/light_bg"
                android:ems="10"
                android:padding="15dp"
                android:maxLength="125"
                android:minHeight="48dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/new_post_toolbar" />

            <EditText
                android:id="@+id/new_post_desc"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="8dp"
                android:padding="15dp"
                android:background="@drawable/light_bg"
                android:gravity="start|top"
                android:hint="@string/add_desc_hint"
                android:inputType="textMultiLine"
                android:textColor="@color/black"
                android:textColorHint="#393939"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/new_post_title" />

            <EditText
                android:id="@+id/new_post_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="8dp"
                android:gravity="start|top"
                android:background="@drawable/light_bg"
                android:ems="10"
                android:padding="15dp"
                android:hint="Job location ..."
                android:inputType="text"
                android:maxLength="125"
                android:minHeight="48dp"
                android:textColor="@color/black"
                android:textColorHint="#393939"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/new_post_desc" />

            <Button
                android:id="@+id/post_btn"
                android:layout_width="250dp"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="50dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="50dp"
                android:padding="16dp"
                android:text="@string/new_post_btn_hint"
                android:background="@drawable/light_bg"
                android:backgroundTint="@color/gray"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_gravity="center"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/new_post_location" />


        </LinearLayout>

    </RelativeLayout>
</androidx.core.widget.NestedScrollView>