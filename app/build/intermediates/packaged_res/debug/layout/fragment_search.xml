<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="SearchFragment"
    tools:context=".SearchFragment"
    android:background="@color/white">

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="15dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Search"
        android:textColor="@color/black"
        android:textSize="27sp" />

    <View
        android:id="@+id/view"
        android:layout_width="40dp"
        android:layout_height="5dp"
        android:layout_below="@id/textView3"
        android:layout_alignStart="@+id/textView3"
        android:background="@drawable/light_bg"
        android:backgroundTint="@color/dark_black" />

    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchview4"
        android:layout_width="123dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textView3"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="20dp"
        android:background="@color/light_white"
        android:backgroundTint="#DCDCDC"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:queryHint="Search Jobs"
        android:textColor="@color/black"
        app:iconifiedByDefault="false"
        app:queryBackground="@android:color/transparent"
        app:searchViewStyle="@style/SearchViewStyle" />




    <HorizontalScrollView
        android:id="@+id/buttons"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_below="@+id/searchview4"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:fillViewport="true"
        android:orientation="horizontal"
        android:paddingHorizontal="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"


            >


            <RadioGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                >

                <RadioButton
                    android:id="@+id/button1"
                    android:layout_width="110dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="25dp"
                    android:text="Title"
                    android:textColor="@color/black"
                    android:background="@drawable/buttons_search_selector"
                    android:button="@android:color/transparent"
                    android:gravity="center"
                    android:checked="true"
                    />

                <RadioButton
                    android:id="@+id/button2"
                    android:layout_width="110dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:text="Description"
                    android:textColor="@color/black"
                    android:background="@drawable/buttons_search_selector"
                    android:button="@android:color/transparent"
                    android:gravity="center"

                    />

                <RadioButton
                    android:id="@+id/button3"
                    android:layout_width="110dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:text="Location"
                    android:textColor="@color/black"
                    android:background="@drawable/buttons_search_selector"
                    android:button="@android:color/transparent"
                    android:gravity="center"

                    />





            </RadioGroup>




        </LinearLayout>

    </HorizontalScrollView>



    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/buttons"
        android:layout_marginTop="16dp"
        android:background="@color/light_white">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/job_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/searchview"
            android:layout_marginStart="14dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            tools:listitem="@layout/job_list_item" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


</RelativeLayout>